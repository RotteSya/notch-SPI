# NotchSPI official pay-as-you-go server — configuration.
# Copy to `.env` and adjust. Every value has a safe default; the server boots with none set
# (mock provider + in-repo SQLite), so you can run it before wiring real vendor keys.

# --- Server ---
HOST=0.0.0.0
PORT=8787
# Public URL of THIS server (used to build absolute links). Must match what the macOS client's
# `official.baseURL` points at.
PUBLIC_BASE_URL=https://notchspi-api.vercel.app

# --- Storage ---
# Production: set a Postgres connection string (Neon/Supabase/RDS; use the POOLED URL on
# serverless). Falls back to SQLite locally, or an EPHEMERAL in-memory store on serverless.
# POSTGRES_URL=postgres://user:pass@host/db
DB_PATH=./data/notchspi.db
# Postgres TLS. Default VERIFIES the server certificate (verify-full) — the billing DB must not
# accept a MITM. Neon/Supabase verify against Node's built-in public roots with no extra config.
#   verify-full (default) — TLS + certificate verification
#   require               — TLS but NO verification (legacy; use only if you must and accept the risk)
#   disable               — no TLS (local/dev; `?sslmode=disable` in the URL implies this too)
# POSTGRES_SSL_MODE=verify-full
# Custom CA for providers not covered by the public roots (e.g. AWS RDS bundle, a private CA):
# POSTGRES_CA_CERT_FILE=/etc/secrets/pg-ca.pem
# ...or inline PEM (literal \n between lines is accepted):
# POSTGRES_CA_CERT=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----

# --- Quota (题数额度制) ---
# The account balance is a number of QUESTIONS; one successful capture costs one question.
# Free questions granted to every newly registered device.
TRIAL_QUESTIONS=180
# Question packs sold on the top-up page (prices are cents in CURRENCY). Malformed values
# fall back to the built-in default catalog.
# PACKS_JSON=[{"id":"pack100","questions":100,"amount_cents":900},{"id":"pack300","questions":300,"amount_cents":2400},{"id":"pack1000","questions":1000,"amount_cents":6800}]
CURRENCY=CNY

# --- Model provider ---
# mock | anthropic | openai. "mock" needs no key and streams a canned answer (dev/testing).
OFFICIAL_PROVIDER=mock
OFFICIAL_MODEL=claude-opus-4-8
OFFICIAL_MAX_TOKENS=4096
# Required when OFFICIAL_PROVIDER=anthropic (the server holds the key; clients never see it).
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
# Required when OFFICIAL_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com

# --- Payments (Stripe Checkout) ---
# Setting STRIPE_SECRET_KEY activates real payments automatically. Prefer a RESTRICTED key
# (rk_..., Checkout Sessions write-only). Create a webhook endpoint in the Stripe Dashboard
# pointing at  <PUBLIC_BASE_URL>/webhooks/stripe  listening to checkout.session.completed,
# and paste its signing secret below.
# STRIPE_SECRET_KEY=rk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Without a Stripe key the dev stub remains (see below).
PAYMENT_PROVIDER=stub
# The stub top-up endpoint is unauthenticated and can credit any balance, so it is DISABLED by
# default (safe for production). Set to 1 ONLY for local development to exercise the top-up flow.
ALLOW_STUB_TOPUP=0

# --- Abuse limits (best-effort, in-memory; see src/rateLimit.ts) ---
# Defense in depth against free-quota farming and parallel-capture abuse. These live per server
# instance, so on serverless treat a platform WAF / edge rule as the real hard limit. Set to 0
# to disable a limit.
# Max anonymous device registrations per client IP per hour.
DEVICE_REG_PER_HOUR=30
# Max simultaneous in-flight captures for a single device token.
CAPTURE_CONCURRENCY_PER_TOKEN=3

LOG_LEVEL=info
